openapi: 3.1.0
info:
  title: AI Work OS Repo Resource API
  version: "2.1.1"
  description: |
    AI Work OS repo access API + Todoist Tasks API.
    Supports docs (read only), notes (read/create/update), code (read/create/update),
    and Todoist task operations.
    Legacy docs endpoints are kept for compatibility during migration.

servers:
  - url: https://ai-work-os.vercel.app

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: API Key

  schemas:
    RequestId:
      type: string
      description: Per-request identifier for tracing and log correlation
      example: fbf3bd6b-5d7f-4c1f-ab91-0b4cc517ed96

    ErrorObject:
      type: object
      properties:
        code:
          type: string
          example: INVALID_REQUEST
        message:
          type: string
          example: file required
        category:
          type: string
          enum:
            - validation
            - auth
            - routing
            - service
            - upstream
            - config
            - internal
        step:
          type: string
        resource:
          type: string
          nullable: true
        action:
          type: string
          nullable: true
        status:
          type: integer
        retryable:
          type: boolean
        details:
          type: object
          additionalProperties: true
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - code
        - message
      additionalProperties: true

    ErrorResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: false
        error:
          $ref: "#/components/schemas/ErrorObject"
      required:
        - ok
        - error
      additionalProperties: true

    DocsListItem:
      type: object
      properties:
        name:
          type: string
        path:
          type: string
        sha:
          type: string
        size:
          type: integer
      additionalProperties: true

    DocsListData:
      type: object
      properties:
        resource:
          type: string
          enum: [docs]
        items:
          type: array
          items:
            $ref: "#/components/schemas/DocsListItem"
        count:
          type: integer
      additionalProperties: true

    DocsListResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          $ref: "#/components/schemas/DocsListData"
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    FileReadData:
      type: object
      properties:
        name:
          type: string
        path:
          type: string
        sha:
          type: string
        size:
          type: integer
        content:
          type: string
        content_length:
          type: integer
        fetched_at:
          type: string
        status:
          type: string
      additionalProperties: true

    FileReadResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          $ref: "#/components/schemas/FileReadData"
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    BulkFileItem:
      type: object
      properties:
        ok:
          type: boolean
        file:
          type: string
        name:
          type: string
        path:
          type: string
        sha:
          type: string
        size:
          type: integer
        content:
          type: string
        content_length:
          type: integer
        fetched_at:
          type: string
        status:
          type: string
        error:
          type: object
          additionalProperties: true
      additionalProperties: true

    DocsBulkResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          type: array
          items:
            $ref: "#/components/schemas/BulkFileItem"
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    RepoTreeItem:
      type: object
      properties:
        path:
          type: string
        name:
          type: string
        type:
          type: string
          enum:
            - file
            - dir
        sha:
          type: string
      additionalProperties: true

    RepoTreeData:
      type: object
      properties:
        resource:
          type: string
          enum:
            - notes
            - code
        items:
          type: array
          items:
            $ref: "#/components/schemas/RepoTreeItem"
        count:
          type: integer
      additionalProperties: true

    RepoTreeResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          $ref: "#/components/schemas/RepoTreeData"
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    WriteRequest:
      type: object
      required:
        - file
        - content
      properties:
        file:
          type: string
        content:
          type: string
        message:
          type: string
        sha:
          type: string
      additionalProperties: false

    WriteResultData:
      type: object
      properties:
        path:
          type: string
        sha:
          type: string
        status:
          type: string
          enum:
            - CREATED
            - UPDATED
      additionalProperties: true

    WriteResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          $ref: "#/components/schemas/WriteResultData"
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    CreateTaskRequest:
      type: object
      required:
        - title
      properties:
        title:
          type: string
        description:
          type: string
        due_string:
          type: string
        labels:
          type: array
          items:
            type: string
        priority:
          type: integer
          minimum: 1
          maximum: 4
        subtasks:
          type: array
          items:
            type: string
      additionalProperties: false

    UpdateTaskRequest:
      type: object
      properties:
        title:
          type: string
        description:
          type: string
        due_date:
          type: string
        labels:
          type: array
          items:
            type: string
        priority:
          type: integer
          minimum: 1
          maximum: 4
        status:
          type: string
          enum:
            - open
            - closed
      additionalProperties: false

    TaskListResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          type: object
          additionalProperties: true
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    TaskCreateResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          type: object
          properties:
            id:
              type: string
            title:
              type: string
          additionalProperties: true
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

    TaskUpdateResponse:
      type: object
      properties:
        ok:
          type: boolean
          const: true
        data:
          type: object
          properties:
            id:
              type: string
            status:
              type: string
          additionalProperties: true
        request_id:
          $ref: "#/components/schemas/RequestId"
      required:
        - ok
        - data
      additionalProperties: true

security:
  - bearerAuth: []

paths:
  /api/docs:
    get:
      operationId: listDocsLegacy
      summary: List docs (legacy endpoint)
      security:
        - bearerAuth: []
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/DocsListResponse"
        "401":
          description: Unauthorized
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /api/docs-read:
    get:
      operationId: readDocLegacy
      summary: Read one doc (legacy endpoint)
      security:
        - bearerAuth: []
      parameters:
        - name: file
          in: query
          required: true
          schema:
            type: string
        - name: refresh
          in: query
          required: false
          schema:
            type: boolean
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/FileReadResponse"
        "400":
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /api/docs-bulk:
    get:
      operationId: readDocsBulkLegacy
      summary: Read multiple docs (legacy endpoint)
      security:
        - bearerAuth: []
      parameters:
        - name: files
          in: query
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/DocsBulkResponse"
        "400":
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorResponse"

  /api/repo-resource:
    get:
      operationId: repoResourceGet
      summary: Read repo resources
      security:
        - bearerAuth: []
      parameters:
        - name: action
          in: query
          required: true
          schema:
            type: string
            enum:
              - list
              - tree
              - read
              - bulk
        - name: resource
          in: query
          required: true
          schema:
            type: string
            enum:
              - docs
              - notes
              - code
        - name: file
          in: query
          required: false
          schema:
            type: string
        - name: files
          in: query
          required: false
          schema:
            type: string
      responses:
        "200":
          description: Success

    post:
      operationId: repoResourceWrite
      summary: Write repo resources
      security:
        - bearerAuth: []
      parameters:
        - name: action
          in: query
          required: true
          schema:
            type: string
            enum:
              - create
              - update
        - name: resource
          in: query
          required: true
          schema:
            type: string
            enum:
              - notes
              - code
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/WriteRequest"
      responses:
        "200":
          description: Success

  /api/tasks:
    get:
      operationId: listTasks
      summary: List Todoist tasks
      security:
        - bearerAuth: []
      parameters:
        - name: project_id
          in: query
          schema:
            type: string
        - name: section_id
          in: query
          schema:
            type: string
        - name: parent_id
          in: query
          schema:
            type: string
        - name: label
          in: query
          schema:
            type: string
        - name: status
          in: query
          schema:
            type: string
            enum:
              - open
              - closed
        - name: cursor
          in: query
          schema:
            type: string
        - name: limit
          in: query
          schema:
            type: integer
            minimum: 1
            maximum: 200
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/TaskListResponse"

    post:
      operationId: createTask
      summary: Create Todoist task
      security:
        - bearerAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateTaskRequest"
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/TaskCreateResponse"

  /api/tasks/{id}:
    patch:
      operationId: updateTask
      summary: Update or close Todoist task
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateTaskRequest"
      responses:
        "200":
          description: Success
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/TaskUpdateResponse"
